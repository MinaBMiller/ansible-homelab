# /etc/nginx/nginx.conf
# Managed by Ansible — manual changes will be overwritten
#
# This is the main nginx config. It sets global behaviour.
# Individual site configs live in /etc/nginx/sites-enabled/.

user www-data;                          # the system user nginx workers run as
worker_processes {{ nginx_worker_processes }};
pid /run/nginx.pid;

events {
    worker_connections {{ nginx_worker_connections }};
    # Accept as many connections as possible when the worker wakes up.
    # More efficient than accepting one at a time.
    multi_accept on;
}

http {
    # ── Performance ───────────────────────────────────────────────────────────

    # sendfile: use kernel-level file transfer instead of copying through userspace.
    # Much faster for serving static files.
    sendfile on;

    # tcp_nopush and tcp_nodelay together: batch packet headers, then send
    # data immediately. Best of both worlds for latency and throughput.
    tcp_nopush on;
    tcp_nodelay on;

    # How long to keep a connection open waiting for another request (seconds).
    # Reduces overhead of re-establishing TCP connections for the same client.
    keepalive_timeout 65;

    # ── MIME Types ────────────────────────────────────────────────────────────
    #
    # MIME types tell the browser what kind of content it's receiving.
    # Without the correct type, browsers may refuse to render CSS or JS.
    include /etc/nginx/mime.types;
    default_type application/octet-stream;

    # ── Security ──────────────────────────────────────────────────────────────

    # Don't reveal the nginx version number in error pages or headers.
    # Knowing the version helps attackers look up known vulnerabilities.
    server_tokens off;

    # Security headers applied to all sites
    {% for header in nginx_security_headers %}
    add_header {{ header.split(' ', 1)[0] }} "{{ header.split(' ', 1)[1] }}";
    {% endfor %}

    # ── Logging ───────────────────────────────────────────────────────────────
    #
    # access_log: one line per HTTP request (IP, URL, status code, bytes sent)
    # error_log:  nginx errors and warnings
    # Both feed into journald and are readable with: journalctl -u nginx

    access_log /var/log/nginx/access.log;
    error_log /var/log/nginx/error.log warn;

    # ── Gzip Compression ──────────────────────────────────────────────────────
    #
    # Compress responses before sending them. Reduces bandwidth, speeds up
    # page loads. The browser decompresses transparently.

    gzip on;
    gzip_vary on;
    gzip_types text/plain text/css application/json application/javascript
               text/xml application/xml image/svg+xml;

    # ── Virtual Hosts ─────────────────────────────────────────────────────────
    # Load all enabled site configs from sites-enabled/
    include /etc/nginx/sites-enabled/*;
}
