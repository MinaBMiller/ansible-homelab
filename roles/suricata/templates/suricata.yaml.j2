# /etc/suricata/suricata.yaml
# Managed by Ansible — manual changes will be overwritten
#
# This is a simplified config for homelab IDS monitoring.
# Full reference: https://docs.suricata.io/en/latest/configuration/

%YAML 1.1
---

# ── Network Variables ─────────────────────────────────────────────────────────
#
# HOME_NET: your local network. Suricata treats this as "expected" traffic.
# EXTERNAL_NET: everything else — potential threat sources.
# Rules reference these variables: e.g., "alert from EXTERNAL_NET to HOME_NET"

vars:
  address-groups:
    HOME_NET: "[{{ suricata_home_net }}]"
    EXTERNAL_NET: "!$HOME_NET"
    HTTP_SERVERS: "$HOME_NET"
    DNS_SERVERS: "$HOME_NET"

  port-groups:
    HTTP_PORTS: "80"
    SHELLCODE_PORTS: "!80"
    SSH_PORTS: "22"

# ── Logging ───────────────────────────────────────────────────────────────────
#
# EVE (Extensible Event Format) is Suricata's main log format.
# It outputs one JSON object per line — easy to parse, search, and ship
# to log aggregation tools like Loki or Elasticsearch.

default-log-dir: /var/log/suricata/

outputs:
  - eve-log:
      enabled: yes
      filetype: regular
      filename: eve.json
      types:
        - alert:
            tagged-packets: yes
        - http:
            extended: yes
        - dns:
            query: yes
            answer: yes
        - tls:
            extended: yes
        - files:
            force-magic: no
        - smtp:
            extended: yes
        - flow
        - netflow
        - stats:
            totals: yes
            threads: no

  - fast:
      enabled: yes
      filename: fast.log

  - stats:
      enabled: yes
      filename: stats.log
      append: yes
      totals: yes
      threads: no

# ── Detection Engine ──────────────────────────────────────────────────────────

detect-engine:
  - profile: medium
  - custom-values:
      toclient-groups: 3
      toserver-groups: 25

# ── App Layer Protocols ───────────────────────────────────────────────────────
#
# Suricata can inspect traffic at the application layer — it understands
# HTTP, DNS, TLS, etc. and can detect attacks specific to each protocol.

app-layer:
  protocols:
    http:
      enabled: yes
    tls:
      enabled: yes
    dns:
      enabled: yes
    ssh:
      enabled: yes
    smtp:
      enabled: yes
    ftp:
      enabled: yes

# ── Rule Files ────────────────────────────────────────────────────────────────
#
# Rules are the signatures Suricata uses to detect threats.
# suricata.rules is the default file that suricata-update generates.

default-rule-path: /var/lib/suricata/rules
rule-files:
  - suricata.rules

# ── Performance ───────────────────────────────────────────────────────────────

threading:
  set-cpu-affinity: no

# ── Network Capture ───────────────────────────────────────────────────────────
#
# af-packet is the Linux kernel's high-performance packet capture method.
# It reads packets directly from the network interface with minimal overhead.

af-packet:
  - interface: {{ suricata_interface }}
    cluster-id: 99
    cluster-type: cluster_flow
    defrag: yes
